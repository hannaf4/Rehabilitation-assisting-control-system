void I2C_ReadSequential(uint8_t devAddr, uint8_t regAddr, uint8_t *data, uint8_t count) {
    I2C1_MSA_R = (devAddr << 1); // Address shifted left 1 bit (Write mode)
    I2C1_MDR_R = regAddr;        // Tell sensor the starting register we want to read from
    I2C1_MCS_R = 0x03;           // START + RUN
    while (I2C1_MCS_R & 0x01);
    
    I2C1_MSA_R = (devAddr << 1) | 0x01; // Address shifted left 1 bit + LSB=1 (Switches line to Read Mode)
       I2C1_MSA_R = (devAddr << 1) | 0x01; // Address shifted left 1 bit + LSB=1 (Switches line to Read Mode)
    
    for(uint8_t i = 0; i < count; i++) {
        // I2C requires different STOP and ACK combinations depending on if it's the 1st byte, middle byte, or last byte
        if(i == 0 && count == 1) I2C1_MCS_R = 0x07; // Only 1 byte total: START + RUN + STOP
        else if(i == 0)          I2C1_MCS_R = 0x0B; // First Byte: START + RUN + ACK
        else if(i == count - 1)  I2C1_MCS_R = 0x05; // Last Byte: RUN + STOP
        else                     I2C1_MCS_R = 0x09; // Middle Bytes: RUN + ACK
        
        while (I2C1_MCS_R & 0x01); // Wait for byte to physically arrive over wire
        data[i] = I2C1_MDR_R;      // Save byte to our array
    }
}


